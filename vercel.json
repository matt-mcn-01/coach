{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.(js|css|jpg|png|ico|svg))", "dest": "/$1" }
  ]
}